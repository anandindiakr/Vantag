# ===========================================================================
# Vantag Platform — Example Environment Variables
# ===========================================================================
# Copy this file to .env and fill in the appropriate values:
#
#   cp .env.example .env        (Linux/macOS)
#   copy .env.example .env      (Windows)
#
# NEVER commit your real .env file to version control.
# See SECURITY.md for secret generation instructions.
# ===========================================================================

# ---------------------------------------------------------------------------
# Platform environment
# ---------------------------------------------------------------------------
# Options: development | staging | production | edge
VANTAG_ENV=development

# ---------------------------------------------------------------------------
# JWT authentication secret  *** ROTATE ON EVERY NEW DEPLOYMENT ***
# ---------------------------------------------------------------------------
# Generate a 32-char+ random secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<set-a-new-secret-here>

# ---------------------------------------------------------------------------
# Face / RTSP encryption key (Fernet)  *** ROTATE ON EVERY NEW DEPLOYMENT ***
# ---------------------------------------------------------------------------
# Generate a Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FACE_ENCRYPTION_KEY=<set-a-new-secret-here>

# ---------------------------------------------------------------------------
# Backward-compat aliases (used by existing code; point to same values above)
# ---------------------------------------------------------------------------
VANTAG_JWT_SECRET=<set-a-new-secret-here>
VANTAG_FACE_KEY=<set-a-new-secret-here>

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_URL=postgresql://vantag:CHANGE_ME@localhost:5434/vantag

# ---------------------------------------------------------------------------
# MQTT broker
# ---------------------------------------------------------------------------
MQTT_BROKER=localhost
MQTT_PORT=1883

# ---------------------------------------------------------------------------
# CORS — comma-separated allowed origins
# ---------------------------------------------------------------------------
VANTAG_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Razorpay (per-region)
# ---------------------------------------------------------------------------
RAZORPAY_KEY_ID_IN=
RAZORPAY_KEY_SECRET_IN=
RAZORPAY_WEBHOOK_SECRET_IN=
RAZORPAY_KEY_ID_SG=
RAZORPAY_KEY_SECRET_SG=
RAZORPAY_WEBHOOK_SECRET_SG=
RAZORPAY_KEY_ID_MY=
RAZORPAY_KEY_SECRET_MY=
RAZORPAY_WEBHOOK_SECRET_MY=

# ---------------------------------------------------------------------------
# Email / SMTP
# ---------------------------------------------------------------------------
VANTAG_SMTP_HOST=smtp.gmail.com
VANTAG_SMTP_PORT=587
VANTAG_SMTP_USER=
VANTAG_SMTP_PASS=
VANTAG_EMAIL_FROM=Vantag <noreply@vantag.com>

# ---------------------------------------------------------------------------
# Model paths (optional overrides; defaults are set in cameras.yaml)
# ---------------------------------------------------------------------------
# VANTAG_YOLO_MODEL=models/weights/yolov8n.pt
# VANTAG_POSE_MODEL=models/weights/yolov8n-pose.pt

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
YOLO_TELEMETRY=False
VANTAG_FACE_RECOGNITION=true
# VANTAG_DEBUG=0
