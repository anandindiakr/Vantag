# ===========================================================================
# Vantag Platform — Example Environment Variables
# ===========================================================================
# Copy this file to .env and fill in the appropriate values:
#
#   cp .env.example .env
#
# NEVER commit your real .env file to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Platform environment
# ---------------------------------------------------------------------------
# Options: development | staging | production | edge
VANTAG_ENV=development

# ---------------------------------------------------------------------------
# Face embedding encryption key
# ---------------------------------------------------------------------------
# Generate a new Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VANTAG_FACE_KEY=<generate-with-Fernet.generate_key().decode()>

# ---------------------------------------------------------------------------
# JWT authentication secret
# ---------------------------------------------------------------------------
# Use a long, random string in production (minimum 32 characters).
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
VANTAG_JWT_SECRET=change-me-in-production

# ---------------------------------------------------------------------------
# MQTT broker
# ---------------------------------------------------------------------------
MQTT_BROKER=localhost
MQTT_PORT=1883

# ---------------------------------------------------------------------------
# Model paths (optional overrides; defaults are set in cameras.yaml)
# ---------------------------------------------------------------------------
# VANTAG_YOLO_MODEL=models/weights/yolov8n.pt
# VANTAG_POSE_MODEL=models/weights/yolov8n-pose.pt
# VANTAG_TRT_ENGINE=models/weights/yolov8n.engine
# VANTAG_POSE_ENGINE=models/weights/yolov8n-pose.engine

# ---------------------------------------------------------------------------
# Reporting
# ---------------------------------------------------------------------------
# Directory where PDF incident reports are written.
# VANTAG_REPORT_DIR=snapshots/reports

# ---------------------------------------------------------------------------
# Development / debug flags
# ---------------------------------------------------------------------------
# Set to 1 to enable verbose debug logging across all modules.
# VANTAG_DEBUG=0
